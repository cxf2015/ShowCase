                <mxCell id="80" value="&lt;b&gt;对比分析&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="84">
                    <mxGeometry x="90" width="100" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="81" value="&lt;b&gt;使用LLM提取中间层特征，表征能力强，泛化性强&lt;/b&gt;&lt;div&gt;&lt;b&gt;但耗时更长0.3s~2s&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, Ubuntu, Cantarell, &amp;quot;Noto Sans&amp;quot;, sans-serif, Arial, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Microsoft YaHei UI&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, sans-serif; letter-spacing: 0.5px; text-align: left; background-color: rgb(255, 255, 255); color: rgba(0, 0, 0, 0.9);&quot;&gt;⭐⭐⭐&lt;/span&gt;&lt;b style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;/b&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.9); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, Ubuntu, Cantarell, &amp;quot;Noto Sans&amp;quot;, sans-serif, Arial, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Microsoft YaHei UI&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, sans-serif; letter-spacing: 0.5px; text-align: left; background-color: rgb(255, 255, 255);&quot;&gt;⭐&lt;/span&gt;&lt;b&gt;&lt;/b&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="84">
                    <mxGeometry y="50" width="120" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="83" value="&lt;b&gt;提取文本语义特征，表征能力一般，&lt;/b&gt;&lt;div&gt;&lt;b&gt;耗时0.02s，提速100倍&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, Ubuntu, Cantarell, &amp;quot;Noto Sans&amp;quot;, sans-serif, Arial, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Microsoft YaHei UI&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, sans-serif; letter-spacing: 0.5px; text-align: left; background-color: rgb(255, 255, 255); color: rgba(0, 0, 0, 0.9);&quot;&gt;⭐⭐⭐&lt;/span&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.9); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, Ubuntu, Cantarell, &amp;quot;Noto Sans&amp;quot;, sans-serif, Arial, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Microsoft YaHei UI&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, sans-serif; letter-spacing: 0.5px; text-align: left; background-color: rgb(255, 255, 255);&quot;&gt;⭐&lt;/span&gt;&lt;b&gt;&lt;/b&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="84">
                    <mxGeometry x="140" y="30" width="130" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="85" value="" style="group" vertex="1" connectable="0" parent="1">
                    <mxGeometry x="560" y="870" width="270" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="86" value="" style="shape=tape;whiteSpace=wrap;html=1;size=0.2;" vertex="1" parent="85">
                    <mxGeometry y="31.666666666666668" width="270" height="158.33333333333334" as="geometry"/>
